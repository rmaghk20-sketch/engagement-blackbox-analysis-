# -*- coding: utf-8 -*-
"""
Reproducible analysis for:
"Opening the Black Box of Behavioral Engagement: Explainable Machine Learning
Evidence from 50,000 Block-Based Programming Projects"

Data: Entry Research Educational Dataset (NAVER Connect Foundation, research
agreement required). Input CSV: one row per project-creator observation with
the eight behavioral variables listed in ALL8 and the composite target column.

Pipeline: 60/20/20 split -> validation-RMSE model selection (early stopping)
-> test evaluation -> Gain importance -> SHAP (summary, dependence, interaction)
-> robustness (creator grouping / preprocessing conditions / construction-only
target). Seed fixed for full reproducibility.
"""
import numpy as np
import pandas as pd
from sklearn.model_selection import train_test_split, GroupKFold
from sklearn.linear_model import LinearRegression
from sklearn.metrics import r2_score, mean_squared_error, mean_absolute_error
import xgboost as xgb
import shap

SEED = 42
ALL8 = ['total_duration', 'sum_blocks', 'avg_block_types', 'sum_likes',
        'sum_comments', 'like_given', 'comments_written', 'login_count']
COMPONENTS = ALL8[:5]          # engagement index components
CONSTRUCTION = ALL8[:3]        # construction-only sensitivity target
DATA = 'project_user_features_50k.csv'   # path to agreement-provided data


def load():
    df = pd.read_csv(DATA)
    # engagement index: equal-weight z-sum of the five components
    z = (df[COMPONENTS] - df[COMPONENTS].mean()) / df[COMPONENTS].std()
    df['engagement'] = z.sum(axis=1)
    return df


def split(df, target='engagement'):
    X_tr, X_tmp, y_tr, y_tmp = train_test_split(
        df[ALL8], df[target], test_size=0.4, random_state=SEED)
    X_val, X_te, y_val, y_te = train_test_split(
        X_tmp, y_tmp, test_size=0.5, random_state=SEED)
    return X_tr, X_val, X_te, y_tr, y_val, y_te


def select_model(X_tr, y_tr, X_val, y_val):
    """Validation-RMSE model selection over a small a-priori grid."""
    best = None
    for depth in [3, 4, 5, 6]:
        for lr in [0.05, 0.1]:
            m = xgb.XGBRegressor(
                n_estimators=1000, max_depth=depth, learning_rate=lr,
                subsample=0.8, colsample_bytree=0.8, random_state=SEED,
                n_jobs=-1, early_stopping_rounds=50, eval_metric='rmse')
            m.fit(X_tr, y_tr, eval_set=[(X_val, y_val)], verbose=False)
            rmse = np.sqrt(mean_squared_error(y_val, m.predict(X_val)))
            if best is None or rmse < best[0]:
                best = (rmse, m)
    return best[1]


def evaluate(m, X, y, label):
    p = m.predict(X)
    print(f'{label}: R2={r2_score(y, p):.4f} '
          f'RMSE={np.sqrt(mean_squared_error(y, p)):.4f} '
          f'MAE={mean_absolute_error(y, p):.4f}')


def gain_importance(m):
    g = m.get_booster().get_score(importance_type='gain')
    t = sum(g.values())
    return {k: round(100 * v / t, 2)
            for k, v in sorted(g.items(), key=lambda x: -x[1])}


def shap_outputs(m, X_te, n=4000):
    rng = np.random.RandomState(SEED)
    Xs = X_te.iloc[rng.choice(len(X_te), n, replace=False)]
    sv = shap.TreeExplainer(m).shap_values(Xs)
    return Xs, sv   # feed to shap.summary_plot / dependence plots


def main():
    df = load()

    # --- primary analysis -------------------------------------------------
    X_tr, X_val, X_te, y_tr, y_val, y_te = split(df)
    m = select_model(X_tr, y_tr, X_val, y_val)
    evaluate(m, X_val, y_val, 'Validation')
    evaluate(m, X_te, y_te, 'Test')
    # baselines
    print('Mean predictor Test R2 =',
          round(r2_score(y_te, np.full(len(y_te), y_tr.mean())), 4))
    ols = LinearRegression().fit(X_tr, y_tr)
    print('OLS Test R2 =', round(r2_score(y_te, ols.predict(X_te)), 4),
          '(consistency check: target is linear in components)')
    print('Gain %:', gain_importance(m))

    # --- construction-only sensitivity -----------------------------------
    z = (df[CONSTRUCTION] - df[CONSTRUCTION].mean()) / df[CONSTRUCTION].std()
    df['engagement_c3'] = z.sum(axis=1)
    X_tr, X_val, X_te, y_tr, y_val, y_te = split(df, 'engagement_c3')
    m3 = select_model(X_tr, y_tr, X_val, y_val)
    evaluate(m3, X_te, y_te, 'Construction-only Test')
    print('Gain %:', gain_importance(m3))


if __name__ == '__main__':
    main()
